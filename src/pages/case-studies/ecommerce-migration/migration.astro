---
import { Icon } from 'astro-icon/components';
import { Code } from 'astro-expressive-code/components';
import MainLayout from '~/layouts/MainLayout.astro';
import SectionCopy from '../../_components/SectionCopy.astro';
import PurpleStardust from '../../_components/landing-page/PurpleStardust.astro';
import StepNavigation from '../_components/StepNavigation.astro';
import AuditReport from '../_components/AuditReport.astro';
import AuditVerdict from '../_components/AuditVerdict.astro';
import KpiTable, { type KpiRow } from '../_components/KpiTable.astro';
import Insight from '~/components/Insight.astro';
import ModificationList from '../_components/ModificationList.astro';
import ModificationGroup from '../_components/ModificationGroup.astro';
import ModificationItem from '../_components/ModificationItem.astro';

// ── Code extracts ────────────────────────────────────────────────────────────

const drivingPortCode = `public interface OrderUseCases {
    OrderId createOrder(CustomerId customerId, String currency);
    void addLine(OrderId orderId, ProductId productId, Quantity quantity, Money unitPrice);
    void placeOrder(OrderId orderId, Address shippingAddress);
    void cancelOrder(OrderId orderId, String reason);
    Order getOrder(OrderId orderId);
    List<Order> getOrdersByCustomer(CustomerId customerId);
}`;

const identifierCode = `public record OrderId(Long value) {
    public OrderId {
        if (value == null) {
            throw new IllegalArgumentException("OrderId value must not be null");
        }
    }
}`;

const moneyCode = `public record Money(BigDecimal amount, String currency) {
    public Money {
        if (amount == null) throw new IllegalArgumentException("Amount must not be null");
        if (currency == null) throw new IllegalArgumentException("Currency must not be null");
        amount = amount.setScale(2, RoundingMode.HALF_UP);
    }

    public static Money zero(String currency) {
        return new Money(BigDecimal.ZERO, currency);
    }

    public Money add(Money other) {
        requireSameCurrency(other);
        return new Money(this.amount.add(other.amount), this.currency);
    }

    public Money multiply(int quantity) {
        return new Money(this.amount.multiply(BigDecimal.valueOf(quantity)), this.currency);
    }

    private void requireSameCurrency(Money other) {
        if (!this.currency.equals(other.currency)) {
            throw new IllegalArgumentException("Currency mismatch");
        }
    }
}`;

// ── KPI tables ───────────────────────────────────────────────────────────────

const kpiRowsHexagonal: KpiRow[] = [
    { dimension: 'DDD Compliance',        value: '0%',   weight: '25%', contribution: '0.0',  threshold: '≥ 90%', status: 'CRITICAL', delta: '='    },
    { dimension: 'Hexagonal Architecture', value: '100%', weight: '25%', contribution: '25.0', threshold: '≥ 90%', status: 'OK',       delta: '+100' },
    { dimension: 'Dependencies',           value: '0%',   weight: '20%', contribution: '0.0',  threshold: '≥ 80%', status: 'CRITICAL', delta: '='    },
    { dimension: 'Coupling',               value: '38%',  weight: '15%', contribution: '5.7',  threshold: '≥ 70%', status: 'CRITICAL', delta: '+8'   },
    { dimension: 'Cohesion',               value: '65%',  weight: '15%', contribution: '9.8',  threshold: '≥ 80%', status: 'WARNING',  delta: '+7'   },
];

const kpiRowsPureDomain: KpiRow[] = [
    { dimension: 'DDD Compliance',        value: '100%', weight: '25%', contribution: '25.0', threshold: '≥ 90%', status: 'OK',       delta: '+100' },
    { dimension: 'Hexagonal Architecture', value: '35%',  weight: '25%', contribution: '8.8',  threshold: '≥ 90%', status: 'CRITICAL', delta: '-65'  },
    { dimension: 'Dependencies',           value: '0%',   weight: '20%', contribution: '0.0',  threshold: '≥ 80%', status: 'CRITICAL', delta: '='    },
    { dimension: 'Coupling',               value: '31%',  weight: '15%', contribution: '4.7',  threshold: '≥ 70%', status: 'CRITICAL', delta: '-7'   },
    { dimension: 'Cohesion',               value: '71%',  weight: '15%', contribution: '10.7', threshold: '≥ 80%', status: 'WARNING',  delta: '+6'   },
];
---

<MainLayout
    title="Migration hexagonale - Étapes 3 & 4 | Migration E-Commerce"
    description="Restructuration hexagonale et purification du domaine : création des ports, identifiants typés, value objects. Score 40/100 puis 49/100."
>
    <!-- Hero Section -->
    <section class="pt-24 pb-16 md:pt-32 md:pb-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
        <PurpleStardust height="h-64 md:h-80" />
        <div class="max-w-4xl mx-auto">
            <div class="mt-8 max-w-3xl">
                <span class="bg-clip-text text-transparent bg-blue-purple-gradient font-semibold text-sm uppercase tracking-wider">
                    Étapes 3 &amp; 4
                </span>
                <h1 class="mt-4 font-heading heading-bold text-4xl md:text-5xl lg:text-6xl text-white text-balance">
                    Migration hexagonale
                </h1>
                <p class="mt-6 text-lg text-astro-gray-200 font-light max-w-2xl">
                    Deux étapes fondamentales : la restructuration hexagonale pose le squelette des ports et services applicatifs, puis la purification du domaine élimine toutes les violations DDD et fait progresser le score de 40 à 49/100.
                </p>
                <div class="mt-6 flex flex-wrap gap-3">
                    <a
                        href="https://github.com/hexaglue/case-study-ecommerce/tree/step/3-hexagonal"
                        title="Voir l'étape 3 sur GitHub"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-4 py-2 group inline-flex items-center justify-center gap-2 rounded-full border border-astro-dark-100/30 hover:border-astro-dark-100/60 text-base font-normal text-astro-gray-200 hover:text-astro-gray-100 bg-astro-dark-600/30 transition-all ease-in-out duration-500"
                    >
                        <Icon name="logos/github" class="size-5" aria-hidden="true" />
                        <code class="text-sm text-purple-400">step/3-hexagonal</code>
                    </a>
                    <a
                        href="https://github.com/hexaglue/case-study-ecommerce/tree/step/4-pure-domain"
                        title="Voir l'étape 4 sur GitHub"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-4 py-2 group inline-flex items-center justify-center gap-2 rounded-full border border-astro-dark-100/30 hover:border-astro-dark-100/60 text-base font-normal text-astro-gray-200 hover:text-astro-gray-100 bg-astro-dark-600/30 transition-all ease-in-out duration-500"
                    >
                        <Icon name="logos/github" class="size-5" aria-hidden="true" />
                        <code class="text-sm text-purple-400">step/4-pure-domain</code>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 1 : Restructuration hexagonale (step-3)                       -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <!-- Modifications step-3 -->
    <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
        <div class="max-w-4xl mx-auto">
            <SectionCopy
                label="Étape 3"
                title="Restructuration hexagonale"
                gradient="bg-blue-purple-gradient"
            >
                L'application est réorganisée selon les principes de l'architecture hexagonale :<br>
                les packages <code>domain/</code>, <code>ports/</code>, <code>application/</code> et <code>infrastructure/</code> séparent le domaine de l'infrastructure, et les services existants sont refactorisés en services applicatifs qui orchestrent les cas d'usage via des ports.
            </SectionCopy>

            <ModificationList class="mt-10">
                <ModificationGroup layer="domain">
                    <ModificationItem
                        action="move"
                        count={13}
                        label="classes domaine"
                        details="vers domain/order/, domain/customer/, domain/product/, domain/inventory/, domain/payment/, domain/shipping/"
                    />
                </ModificationGroup>
                <ModificationGroup layer="ports">
                    <ModificationItem
                        action="define"
                        count={7}
                        label="driving ports"
                        details="OrderUseCases, CustomerUseCases, ProductUseCases, InventoryUseCases, PaymentUseCases, ShippingUseCases, CartUseCases dans ports/in/"
                    />
                    <ModificationItem
                        action="define"
                        count={8}
                        label="driven ports"
                        details="OrderRepository, CustomerRepository, ProductRepository, InventoryRepository, PaymentRepository, ShipmentRepository, NotificationSender, PaymentGateway dans ports/out/"
                    />
                </ModificationGroup>
                <ModificationGroup layer="application">
                    <ModificationItem
                        action="create"
                        count={7}
                        label="services applicatifs"
                        details="OrderApplicationService, CustomerApplicationService, etc. dans application/"
                    />
                </ModificationGroup>
                <ModificationGroup layer="adapters">
                    <ModificationItem
                        action="implement"
                        count={6}
                        label="adaptateurs JPA"
                        details="JpaOrderRepository extends JpaRepository, OrderRepository dans infrastructure/persistence/"
                    />
                    <ModificationItem
                        action="implement"
                        count={2}
                        label="adaptateurs externes"
                        details="PaymentGatewayAdapter, NotificationAdapter dans infrastructure/external/"
                    />
                </ModificationGroup>
            </ModificationList>

            <Insight>
                <ul>
                    <li><strong>Driving ports</strong> (ports entrants) : interfaces qui exposent les cas d'usage au monde extérieur, par exemple <code>OrderUseCases</code></li>
                    <li><strong>Driven ports</strong> (ports sortants) : interfaces qui abstraient les dépendances externes, par exemple <code>OrderRepository</code> ou <code>NotificationSender</code></li>
                </ul>
                <p>Cette inversion de dépendance permet au domaine de ne dépendre que d'abstractions, pas d'implémentations concrètes.</p>
            </Insight>
        </div>
    </section>

    <!-- Code step-3 : Driving port -->
    <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
        <div class="max-w-4xl mx-auto">
            <SectionCopy
                label="Code"
                title="Exemple de driving port"
                gradient="bg-blue-purple-gradient"
            >
                Un driving port définit un cas d'usage métier sans référence à une technologie.<br>
                HexaGlue détecte automatiquement ce pattern et classe l'interface comme <code>DRIVING_PORT</code>.
            </SectionCopy>

            <div class="mt-10">
                <Code code={drivingPortCode} lang="java" title="OrderUseCases.java - Driving Port" />
            </div>

            <Insight>
                <ul>
                    <li>L'interface ne contient que du métier : pas d'annotation Spring, pas d'import JPA</li>
                    <li>Les types utilisés (<code>OrderId</code>, <code>CustomerId</code>, <code>Money</code>) sont des concepts domaine, pas des primitifs</li>
                    <li>HexaGlue détecte ce pattern et le fait apparaître dans l'inventaire architectural comme <code>DrivingPort</code></li>
                </ul>
            </Insight>
        </div>
    </section>

    <!-- Audit step-3 -->
    <AuditReport description="Résultat après restructuration hexagonale : réorganisation des packages, création des ports et services applicatifs.">

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Verdict"
                    title="Verdict : étape 3"
                    gradient="bg-orange-yellow-gradient"
                >
                    Le score atteint 40/100 grâce à la restructuration hexagonale.<br>
                    La dimension Hexagonal Architecture passe à 100%, mais le domaine reste pollué par JPA et les entités n'ont toujours pas d'identifiants typés.
                </SectionCopy>

                <div class="mt-10">
                    <AuditVerdict
                        score={40}
                        grade="F"
                        status="FAILED"
                        violations={{ critical: 18, major: 0 }}
                        delta={{ score: 27, violations: -25 }}
                    />
                </div>

                <Insight>
                    <ul>
                        <li><strong>+27 points</strong> par rapport au diagnostic initial (13 vers 40) : la structure hexagonale contribue très fortement au score</li>
                        <li><strong>0 violation Major</strong> : tous les ports ont leur adaptateur, les directions sont respectées</li>
                        <li><strong>18 violations Critical</strong> restantes : 9 entités sans identifiant typé (<code>entity-identity</code>) et 9 classes avec imports JPA dans le domaine (<code>domain-purity</code>)</li>
                    </ul>
                    <p>Le score est plafonné parce que le domaine n'est pas encore purifié. La structure existe, mais le contenu reste couplé à l'infrastructure.</p>
                </Insight>
            </div>
        </section>

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Score"
                    title="Décomposition du score : étape 3"
                    gradient="bg-orange-yellow-gradient"
                >
                    Hexagonal Architecture atteint 100% grâce aux ports et adaptateurs, mais DDD Compliance reste à 0% tant que les entités portent des annotations JPA et des identifiants non typés.
                </SectionCopy>

                <div class="mt-10">
                    <KpiTable rows={kpiRowsHexagonal} total="40.5" />
                </div>

                <Insight>
                    <ul>
                        <li><strong>Hexagonal Architecture</strong> à 100% (+100) : tous les ports driving et driven sont créés, chacun a son adaptateur, et les directions sont correctes</li>
                        <li><strong>Coupling</strong> à 38% (+8) : la séparation en packages améliore les dépendances entre couches</li>
                        <li><strong>Cohesion</strong> à 65% (+7) : les classes sont regroupées par sous-domaine métier, ce qui améliore la cohésion mesurée</li>
                        <li><strong>DDD Compliance</strong> à 0% et <strong>Dependencies</strong> à 0% : les entités n'ont toujours pas d'identifiants typés et le domaine dépend encore de JPA</li>
                    </ul>
                </Insight>
            </div>
        </section>

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Ce que révèle l'audit"
                    title="Pourquoi DDD Compliance reste à 0% ?"
                    gradient="bg-orange-yellow-gradient"
                >
                    La restructuration hexagonale est nécessaire mais insuffisante.<br>
                    Le score DDD ne progressera qu'après la purification du domaine : suppression des annotations JPA et introduction des patterns tactiques DDD.
                </SectionCopy>

                <Insight class="mt-10" variant="amber">
                    <ul>
                        <li>Les ports existent mais les entités domaine embarquent encore <code>@Entity</code>, <code>@Id</code> et <code>Long id</code> via <code>BaseEntity</code></li>
                        <li>Sans identifiant typé (<code>OrderId</code>), HexaGlue ne peut pas promouvoir les entités en <code>AGGREGATE_ROOT</code></li>
                        <li>Sans aggregate root détecté, la dimension <strong>DDD Compliance</strong> reste à 0%, bridant le score global à 40</li>
                        <li>La prochaine étape consiste à créer les identifiants typés, value objects et domain events, puis à supprimer toutes les annotations JPA du domaine</li>
                    </ul>
                </Insight>
            </div>
        </section>

    </AuditReport>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 2 : Purification du domaine (step-4)                          -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <!-- Modifications step-4 -->
    <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
        <div class="max-w-4xl mx-auto">
            <SectionCopy
                label="Étape 4"
                title="Purification du domaine"
                gradient="bg-blue-purple-gradient"
            >
                Le domaine est purifié : toutes les annotations JPA sont supprimées et remplacées par des patterns tactiques DDD.<br>
                Les identifiants typés et les value objects permettent à HexaGlue d'inférer la classification complète sans aucune annotation explicite.
            </SectionCopy>

            <ModificationList class="mt-10">
                <ModificationGroup layer="domain">
                    <ModificationItem
                        action="create"
                        count={6}
                        label="identifiants typés"
                        details="OrderId, CustomerId, ProductId, PaymentId, ShipmentId, InventoryId (records Java avec validation)"
                    />
                    <ModificationItem
                        action="create"
                        count={4}
                        label="value objects"
                        details="Money, Address, Email, Quantity avec validation et comportement métier"
                    />
                    <ModificationItem
                        action="create"
                        count={1}
                        label="domain event"
                        details="OrderPlacedEvent capturant le fait métier avec OrderId, CustomerId et Money"
                    />
                    <ModificationItem
                        action="purify"
                        count={9}
                        label="classes domaine"
                        details="suppression @Entity / @ManyToOne / extends BaseEntity, ajout logique métier (place(), cancel()...)"
                    />
                    <ModificationItem
                        action="remove"
                        label="BaseEntity"
                        details="chaque agrégat définit son propre identifiant typé, la hiérarchie technique disparaît"
                    />
                </ModificationGroup>
                <ModificationGroup layer="adapters">
                    <ModificationItem
                        action="remove"
                        count={6}
                        label="repositories JPA"
                        details="JpaOrderRepository, JpaCustomerRepository, etc. supprimés car le domaine purifié n'est plus compatible"
                    />
                </ModificationGroup>
            </ModificationList>

            <Insight>
                <p>C'est la transformation fondamentale du DDD : séparer le modèle métier de l'infrastructure.</p>
                <ul>
                    <li><strong>Identifiants typés</strong> (records) : remplacent les <code>Long</code> génériques issus de <code>BaseEntity</code>, chaque agrégat a son propre type d'identifiant</li>
                    <li><strong>Value objects</strong> : encapsulent les règles de validation et le comportement, par exemple <code>Money</code> sait additionner et multiplier des montants</li>
                    <li><strong>Agrégats purifiés</strong> : protègent leurs invariants via des méthodes métier (<code>place()</code>, <code>markPaid()</code>, <code>cancel()</code>)</li>
                    <li><strong>Repositories JPA supprimés</strong> : le domaine purifié n'est plus compatible avec les anciens adaptateurs, ils seront régénérés par HexaGlue</li>
                </ul>
            </Insight>
        </div>
    </section>

    <!-- Code step-4 : Identifiant typé + Value Object -->
    <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
        <div class="max-w-4xl mx-auto">
            <SectionCopy
                label="Code"
                title="Identifiants typés et value objects"
                gradient="bg-blue-purple-gradient"
            >
                Deux patterns clés illustrent la purification du domaine.<br>
                HexaGlue détecte ces structures automatiquement et classe <code>OrderId</code> comme <code>IDENTIFIER</code> et <code>Money</code> comme <code>VALUE_OBJECT</code>.
            </SectionCopy>

            <div class="mt-10 space-y-6">
                <Code code={identifierCode} lang="java" title="OrderId.java - Identifiant typé" />
                <Code code={moneyCode} lang="java" title="Money.java - Value Object" />
            </div>

            <Insight>
                <ul>
                    <li>Le <strong>record</strong> remplace le <code>Long</code> générique hérité de <code>BaseEntity</code> : on ne peut plus confondre un <code>OrderId</code> avec un <code>CustomerId</code> à la compilation</li>
                    <li>La <strong>validation au constructeur</strong> garantit qu'aucun identifiant nul ni montant invalide ne circule dans le domaine</li>
                    <li><code>Money.add()</code> et <code>Money.multiply()</code> retournent une nouvelle instance : l'<strong>immutabilité</strong> est garantie par le record</li>
                    <li>Ces deux patterns sont détectés automatiquement par HexaGlue sans aucune annotation supplémentaire</li>
                </ul>
            </Insight>
        </div>
    </section>

    <!-- Audit step-4 -->
    <AuditReport description="Résultat après purification du domaine et création des patterns tactiques DDD.">

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Verdict"
                    title="Verdict : étape 4"
                    gradient="bg-orange-yellow-gradient"
                >
                    Le score progresse à 49/100 et l'audit passe au statut <strong>Passed with Warnings</strong>.<br>
                    DDD Compliance atteint 100% et toutes les violations Critical disparaissent en une seule étape.
                </SectionCopy>

                <div class="mt-10">
                    <AuditVerdict
                        score={49}
                        grade="F"
                        status="PASSED_WITH_WARNINGS"
                        violations={{ critical: 0, major: 13 }}
                        delta={{ score: 9, violations: -5 }}
                    />
                </div>

                <Insight>
                    <ul>
                        <li><strong>+9 points</strong> (40 vers 49) : la purification du domaine est le levier DDD le plus puissant de la migration</li>
                        <li><strong>0 violation Critical</strong> : les violations <code>domain-purity</code> et <code>entity-identity</code> disparaissent complètement</li>
                        <li><strong>13 violations Major</strong> (-5) : 6 driven ports sans adaptateur (repositories JPA supprimés) et 7 services applicatifs avec annotations Spring</li>
                    </ul>
                    <p>Ces violations seront éliminées à l'étape suivante par la génération automatique de l'infrastructure.</p>
                </Insight>
            </div>
        </section>

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Score"
                    title="Décomposition du score : étape 4"
                    gradient="bg-orange-yellow-gradient"
                >
                    La dimension DDD Compliance bondit à 100% grâce aux 6 identifiants typés, aux 4 value objects et à la pureté totale du domaine.<br>
                    La dimension Hexagonal Architecture recule temporairement car les repositories JPA supprimés laissent 6 driven ports sans adaptateur.
                </SectionCopy>

                <div class="mt-10">
                    <KpiTable rows={kpiRowsPureDomain} total="49.2" />
                </div>

                <Insight>
                    <ul>
                        <li><strong>DDD Compliance</strong> à 100% (+100) : tous les agrégats ont des identifiants typés, le domaine est pur, les value objects et le domain event sont correctement classifiés</li>
                        <li><strong>Hexagonal Architecture</strong> à 35% (-65) : la suppression des repositories JPA laisse 6 driven ports sans adaptateur, cette chute est temporaire</li>
                        <li><strong>Cohesion</strong> à 71% (+6) : les agrégats regroupent des concepts cohérents avec leur logique métier encapsulée</li>
                        <li><strong>Coupling</strong> à 31% (-7) : le découplage des agrégats entre eux (via les identifiants typés plutôt que les références directes) améliore cette métrique</li>
                    </ul>
                </Insight>
            </div>
        </section>

        <section class="py-16 md:py-20 relative w-full max-w-4xl mx-auto px-4 sm:px-8">
            <div class="max-w-4xl mx-auto">
                <SectionCopy
                    label="Point d'inflexion DDD"
                    title="Pourquoi le score DDD passe de 0% à 100% ?"
                    gradient="bg-orange-yellow-gradient"
                >
                    La purification du domaine est le point d'inflexion de toute migration DDD.<br>
                    Tant que le domaine embarque des annotations techniques, HexaGlue ne peut pas inférer la classification complète.
                </SectionCopy>

                <Insight class="mt-10" variant="green" icon="ri:sparkling-2-line">
                    <ul>
                        <li>Les identifiants typés (<code>OrderId</code>, <code>CustomerId</code>...) permettent à HexaGlue de promouvoir les 6 entités en <strong>Aggregate Root</strong></li>
                        <li>Le passage de <code>Entity</code> à <code>AGGREGATE_ROOT</code> fait passer DDD Compliance de 0% à 100% d'un coup</li>
                        <li>La suppression des annotations JPA du domaine élimine les 9 violations <code>domain-purity</code> et valide la métrique <code>Domain purity: 100%</code></li>
                        <li>Les value objects (<code>Money</code>, <code>Address</code>, <code>Email</code>, <code>Quantity</code>) sont détectés automatiquement et enrichissent l'inventaire architectural</li>
                    </ul>
                    <p>Les 13 violations restantes sont toutes des violations <code>Major</code> liées à l'infrastructure : elles disparaîtront à l'étape suivante avec la génération automatique.</p>
                </Insight>
            </div>
        </section>

    </AuditReport>

    <!-- Navigation -->
    <section class="py-16 relative">
        <div class="w-full max-w-4xl mx-auto px-4 sm:px-8">
            <StepNavigation
                prev={{ href: '/case-studies/ecommerce-migration/', label: 'Diagnostic initial' }}
                next={{ href: '/case-studies/ecommerce-migration/result/', label: 'Résultat final' }}
            />
        </div>
        <div
            class="absolute inset-x-0 bottom-0 h-[50vw] translate-y-[60%] bg-blue-purple-gradient opacity-50 mask-radial-gradient pointer-events-none"
        ></div>
    </section>
</MainLayout>
